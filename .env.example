# =============================================================================
# Variables nuevas requeridas tras la auditoría de seguridad. Copia a .env y
# completa los valores reales. Rota TODOS los secretos previos por las dudas.
# =============================================================================

# Sesión admin (firma de cookie) — generar con: openssl rand -hex 32
ADMIN_SESSION_SECRET=

# Login admin (NO usar la contraseña antigua que estaba hardcodeada)
ADMIN_EMAIL=
# Hash SHA-256 hex de la contraseña. Generar con:
#   echo -n "tu_password" | shasum -a 256
ADMIN_PASSWORD_SHA256=

# Cron de Vercel — generar con: openssl rand -hex 32
# Vercel envía automáticamente "Authorization: Bearer ${CRON_SECRET}"
CRON_SECRET=

# Cupones de testing en entornos no productivos (omitir o "false" en prod)
ADMIN_COUPONS_ENABLED=false

# (Webhook de PayPal opcional, ya soportado por el código)
PAYPAL_WEBHOOK_ID=
